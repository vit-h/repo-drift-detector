{
  "sourcePath": "C:\\Path\\To\\Source",
  "targetPath": "C:\\Path\\To\\Target",
  "outputPath": "./reports",
  "includeExtensions": [
    ".sql"
  ],
  "excludeExtensions": [
    ".zip"
  ],
  "ignoreFolders": [
    "Misc",
    "*_backup",
    "temp*"
  ],
  "ignoreCase": false,
  "sortInserts": true,
  "maxFileSizeMb": 100,
  "maxThreads": 0,
  "bufferSize": 64,
  "allowedSubstitutions": [
    {
      "name": "TimeZone Conversion - Basic GETDATE()",
      "source": "GETDATE()",
      "target": "cast(getdate() AT TIME ZONE 'UTC' AT TIME ZONE 'Pacific Standard Time' as datetime)",
      "ignoreCase": true,
      "trimWhitespaceAround": true,
      "normalizeInternalWhitespace": false,
      "reportMatched": true,
      "allowStructuralChanges": false
    },
    {
      "name": "Filegroup Removal - ON [PRIMARY]",
      "source": "ON [PRIMARY]",
      "target": "",
      "ignoreCase": true,
      "trimWhitespaceAround": true,
      "reportMatched": true
    },
    {
      "name": "Statement Terminator - Semicolon Addition",
      "source": "",
      "target": ";",
      "ignoreCase": false,
      "trimWhitespaceAround": true,
      "reportMatched": false
    }
  ],
  "whitelistLinePatterns": [
    {
      "name": "Line exists only in source",
      "contains": "RowRevision]",
      "existsInSource": true,
      "existsInTarget": false
    },
    {
      "name": "GRANT statements",
      "contains": "GRANT SELECT ON",
      "existsInSource": false,
      "existsInTarget": true
    }
  ],
  "whitelistFilePatterns": [
    {
      "name": "Data files - Allow source missing lines",
      "pattern": "*_Data.sql",
      "allowLineMissingInSource": true,
      "allowLineMissingInTarget": false,
      "allowModified": true
    }
  ]
}