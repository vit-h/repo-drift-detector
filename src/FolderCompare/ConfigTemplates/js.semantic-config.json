{
  "description": "Semantic similarity configuration for JavaScript/TypeScript - Detects differences in function and class definitions",
  
  "threshold": 0.40,
  "lcsWeight": 0.70,
  "tokenWeight": 0.30,
  
  "identifierPatterns": [
    {
      "name": "ES6 Class Definition",
      "pattern": "class\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "options": "None",
      "priority": 10,
      "description": "Matches ES6 class definitions"
    },
    {
      "name": "Function Declaration",
      "pattern": "function\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*\\(",
      "options": "None",
      "priority": 20,
      "description": "Matches function declarations"
    },
    {
      "name": "Arrow Function with Variable",
      "pattern": "(?:const|let|var)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*=\\s*(?:async\\s+)?\\([^)]*\\)\\s*=>",
      "options": "None",
      "priority": 25,
      "description": "Matches arrow functions assigned to variables"
    },
    {
      "name": "TypeScript Interface",
      "pattern": "interface\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "options": "None",
      "priority": 15,
      "description": "Matches TypeScript interface definitions"
    },
    {
      "name": "TypeScript Type Alias",
      "pattern": "type\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*=",
      "options": "None",
      "priority": 18,
      "description": "Matches TypeScript type alias definitions"
    },
    {
      "name": "Export Named",
      "pattern": "export\\s+(?:const|let|var|function|class)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "options": "None",
      "priority": 30,
      "description": "Matches named exports"
    }
  ],
  
  "commonIdentifiers": [
    "this",
    "that",
    "self",
    "constructor",
    "prototype",
    "undefined",
    "null",
    "true",
    "false",
    "async",
    "await",
    "Promise",
    "Array",
    "Object",
    "String",
    "Number",
    "Boolean",
    "Function",
    "console",
    "log",
    "error",
    "warn",
    "info",
    "get",
    "set",
    "post",
    "put",
    "delete",
    "update",
    "create",
    "read",
    "write",
    "render",
    "mount",
    "unmount",
    "data",
    "result",
    "value",
    "item",
    "config",
    "context",
    "props",
    "state",
    "event",
    "callback",
    "handler",
    "request",
    "response"
  ],
  
  "tokenDelimiters": [
    " ",
    "\t",
    "\n",
    "(",
    ")",
    "[",
    "]",
    "{",
    "}",
    ",",
    ".",
    ";",
    ":",
    "=",
    "<",
    ">",
    "+",
    "-",
    "*",
    "/",
    "%",
    "&",
    "|",
    "^",
    "~",
    "!",
    "?",
    "@",
    "#",
    "$"
  ]
}
