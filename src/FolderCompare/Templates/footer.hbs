    <div style='margin-top: 50px; padding: 20px; text-align: center; color: #858585; border-top: 1px solid #3e3e3e;'>
        Generated by FolderCompare Tool
    </div>
    <button class='back-to-top' id='backToTop' onclick='scrollToTop()' title='Back to Top'>↑</button>
    <script>
        // Show/hide back to top button based on scroll position
        window.addEventListener('scroll', function() {
            const backToTop = document.getElementById('backToTop');
            if (window.pageYOffset > 300) {
                backToTop.classList.add('visible');
            } else {
                backToTop.classList.remove('visible');
            }
        });
        
        function scrollToTop() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        }
    </script>
</body>
</html>
